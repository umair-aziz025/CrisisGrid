{
  "expo": {
    "name": "CrisisGrid",
    "slug": "crisisgrid",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "crisisgrid",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-light.png",
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain",
      "dark": {
        "image": "./assets/splash-dark.png",
        "backgroundColor": "#0A0F1A"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.crisisgrid.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CrisisGrid uses your location to broadcast crises near you and route nearby volunteers to active requests.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CrisisGrid uses your location to keep volunteer dispatch accurate while you're on duty.",
        "NSMicrophoneUsageDescription": "CrisisGrid records voice notes so you can quickly send audio messages in coordination chat.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["location", "fetch", "remote-notification"],
        "NSUserNotificationUsageDescription": "CrisisGrid sends critical emergency alerts and status updates about your requests.",
        "NSCriticalAlertUsageDescription": "CrisisGrid uses critical alerts for life-threatening emergency notifications."
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "package": "org.crisisgrid.mobile",
      "googleServicesFile": "./google-services.json",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "useNextNotificationsApi": true,
      "notification": {
        "icon": "./assets/notification-icon.png",
        "color": "#2BB3F2",
        "androidMode": "default",
        "androidCollapsedTitle": "CrisisGrid Alert"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CrisisGrid to use your location while on duty.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow CrisisGrid to access the microphone to send voice messages in coordination chat."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2BB3F2",
          "androidMode": "default",
          "androidCollapsedTitle": "CrisisGrid Alert"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.svg"
    },
    "extra": {
      "apiBaseUrl": "https://aidbridge-34695e4b061e.herokuapp.com/",
      "googleDirectionsKey": "YOUR_GOOGLE_MAPS_API_KEY",
      "eas": {
        "projectId": "7fdb0a01-189c-4da4-9702-81865ba76f59"
      }
    }
  }
}
