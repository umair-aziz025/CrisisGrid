EXPO_PUBLIC_API_BASE_URL=https://aidbridge-34695e4b061e.herokuapp.com

# Optional. When set, the live map switches from straight-line ETAs to
# real driving polylines (with alternative routes) via Google Directions.
# Without this key the route still draws and shows distance + ETA, but
# uses a Haversine straight line + average-speed estimate.
EXPO_PUBLIC_GOOGLE_DIRECTIONS_KEY=
